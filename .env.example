# =============================================================================
# TubeBrief 환경 변수 템플릿
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 ".env.local" 이름으로 복사합니다.
#        cp .env.example .env.local   (또는 윈도우: copy .env.example .env.local)
#   2) 아래 빈 값들을 실제 키로 채웁니다.
#   3) ".env.local" 은 절대 git 에 올리지 않습니다 (.gitignore 에 이미 포함됨).
#
# 중요 (CLAUDE.md 절대 규칙 1):
#   - "NEXT_PUBLIC_" 으로 시작하는 변수만 브라우저에 노출됩니다.
#   - SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY, CRON_SECRET 은
#     절대 클라이언트 컴포넌트나 'use client' 파일에서 import 하지 마세요.
#     이 키들은 오직 src/app/api/... (API Route) 안에서만 사용합니다.
# =============================================================================


# --- Supabase ---------------------------------------------------------------
# Supabase 프로젝트 대시보드 > Project Settings > API 에서 복사합니다.

# 프로젝트 URL (예: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key — 브라우저에서 사용 가능. RLS 정책으로 보호.
# (구버전 Supabase 에서는 "anon key" 라고 불렸던 키. 새 방식은 publishable key.)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — 서버 사이드(API Route) 전용. RLS 를 우회하므로 절대 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=


# --- LLM API 키 (둘 중 하나만 채워도 됨) -----------------------------------
# 기본은 Claude Haiku 또는 GPT-4o-mini (저비용 모델).

# Anthropic (Claude Haiku) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o-mini) — https://platform.openai.com/api-keys
OPENAI_API_KEY=


# --- Cron 인증 ---------------------------------------------------------------
# 자동 실행(Cron) 이 우리 API 를 호출할 때, 외부에서 마음대로 호출하지 못하도록
# 비밀 문자열을 헤더에 담아 보냅니다. 임의의 긴 랜덤 문자열을 사용합니다.
CRON_SECRET=
