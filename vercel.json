{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/route.ts": { "maxDuration": 60 },
    "src/app/api/process/route.ts": { "maxDuration": 60 },
    "src/app/api/summarize/route.ts": { "maxDuration": 60 }
  }
}
